BOT_TOKEN=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=400
# Per-request deadline (seconds) for a single Gemini call; stalls are retried.
GEMINI_TIMEOUT_SECONDS=30
PERSONA_PATH=config/persona/vynnychanka.md
MESSAGES_PATH=config/messages.toml
PERSONA_ARCHIVE_DIR=config/persona/archive
MAX_USER_TEXT_LENGTH=4000
DROP_PENDING_UPDATES=true
RATE_LIMIT_USER_CAPACITY=5
RATE_LIMIT_USER_REFILL_PER_MINUTE=6
RATE_LIMIT_CHAT_CAPACITY=10
RATE_LIMIT_CHAT_REFILL_PER_MINUTE=15
RATE_LIMIT_NOTICE_PER_MINUTE=1
RATE_LIMIT_BUCKET_MAX_KEYS=10000
# Comma-separated Telegram user IDs allowed to run /setprompt and /currentprompt.
# Empty disables all admin commands.
ADMIN_USER_IDS=
LOG_LEVEL=INFO
